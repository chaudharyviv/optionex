# ─────────────────────────────────────────────────────────────────
# OPTIONEX — Environment Configuration
# Copy this to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────────

# Trading Mode: demo | paper | production
TRADING_MODE=demo

# Groww API (required for live data)
GROWW_API_KEY=your_api_key_here
GROWW_API_SECRET=your_api_secret_here
GROWW_TOTP_SECRET=your_totp_secret_here
GROWW_ACCESS_TOKEN=

# LLM Providers
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# News (Tavily)
TAVILY_API_KEY=your_tavily_key_here

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk Parameters (override defaults from config.py)
CAPITAL_INR=200000
RISK_PCT_PER_TRADE=2.0
MAX_OPEN_POSITIONS=3
DAILY_LOSS_LIMIT_PCT=5.0

# Production safety
PRODUCTION_CONFIRMED=false
